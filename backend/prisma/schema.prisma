// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Category {
  id    Int     @id @default(autoincrement())
  name  String  @unique @db.VarChar(100)
  items Item[]
  @@map("categories")
}

model User {
  id             Int      @id @default(autoincrement())
  nim_nip        String   @unique @db.VarChar(50)
  name           String   @db.VarChar(255)
  email          String   @unique @db.VarChar(255)
  password       String   @db.VarChar(255)
  role           Role     @default(user)
  phone_number   String?  @db.VarChar(20)
  refresh_token  String?  @db.Text
  created_at     DateTime @default(now()) @db.Timestamp(0)
  updated_at     DateTime @default(now()) @updatedAt @db.Timestamp(0)
  
  items          Item[]   @relation("UserItems")
  verified_items Item[]   @relation("AdminVerifiedItems")
  claims         Claim[]  @relation("UserClaims")
  handled_claims Claim[]  @relation("AdminClaims")
  comments       Comment[]
  boosts         Boost[]

  @@map("users")
}

enum Role {
  admin
  user
}

model Item {
  id             Int        @id @default(autoincrement())
  user_id        Int
  category_id    Int
  type           ItemType
  title          String     @db.VarChar(255)
  slug           String?    @unique @db.VarChar(255)
  description    String     @db.Text
  location       String     @db.VarChar(255)
  date_time      DateTime   @db.DateTime(0)
  image_path     String?    @db.VarChar(255)
  status         ItemStatus
  verified_by_id Int?
  verified_at    DateTime?
  created_at     DateTime   @default(now()) @db.Timestamp(0)
  updated_at     DateTime   @default(now()) @updatedAt @db.Timestamp(0)

  user        User      @relation("UserItems", fields: [user_id], references: [id], onDelete: Cascade)
  verified_by User?     @relation("AdminVerifiedItems", fields: [verified_by_id], references: [id], onDelete: SetNull)
  category    Category  @relation(fields: [category_id], references: [id], onDelete: Restrict)
  claims      Claim[]
  comments    Comment[]
  boosts      Boost[]

  @@index([category_id])
  @@index([type])
  @@index([status])
  @@map("items")
}

enum ItemType {
  lost
  found
}

enum ItemStatus {
  pending_verification
  available
  returned
  searching
  resolved
}

model Claim {
  id                Int         @id @default(autoincrement())
  item_id           Int
  user_id           Int
  proof_description String      @db.Text
  proof_image_path  String?     @db.VarChar(255)
  status            ClaimStatus @default(pending)
  admin_notes       String?     @db.Text
  processed_by_id   Int?
  processed_at      DateTime?
  created_at        DateTime    @default(now()) @db.Timestamp(0)
  updated_at        DateTime    @default(now()) @updatedAt @db.Timestamp(0)

  item         Item  @relation(fields: [item_id], references: [id], onDelete: Cascade)
  user         User  @relation("UserClaims", fields: [user_id], references: [id], onDelete: Cascade)
  processed_by User? @relation("AdminClaims", fields: [processed_by_id], references: [id], onDelete: SetNull)

  @@unique([item_id, user_id])
  @@map("claims")
}

enum ClaimStatus {
  pending
  approved
  rejected
}

model Comment {
  id         Int      @id @default(autoincrement())
  item_id    Int
  user_id    Int
  text       String   @db.Text
  created_at DateTime @default(now()) @db.Timestamp(0)

  item       Item     @relation(fields: [item_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([item_id])
  @@index([user_id])
  @@map("comments")
}

model Boost {
  id         Int      @id @default(autoincrement())
  item_id    Int
  user_id    Int
  created_at DateTime @default(now()) @db.Timestamp(0)

  item       Item     @relation(fields: [item_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([item_id, user_id])
  @@map("boosts")
}




